# Copy this file to .env.local and fill in your values.
#
# Ready Player Me avatar URL.
# Create one at https://readyplayer.me/avatar — when done, the platform
# gives you a URL that looks like:
#   https://models.readyplayer.me/<your-id>.glb
# Paste it here. If unset, the page falls back to /models/avatar.glb
# (the Three.js Soldier demo character).
NEXT_PUBLIC_AVATAR_URL=
